{
  "name": "@smui/common",
  "version": "8.0.3",
  "description": "Svelte Material UI - Common",
  "type": "module",
  "svelte": "./dist/index.js",
  "exports": {
    "./package.json": {
      "types": "./package.json",
      "svelte": "./package.json"
    },
    ".": {
      "types": "./src/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./classadder": {
      "types": "./src/classadder/index.d.ts",
      "svelte": "./dist/classadder/index.js"
    },
    "./events": {
      "types": "./src/events/index.d.ts",
      "svelte": "./dist/events/index.js"
    },
    "./internal": {
      "types": "./src/internal/index.d.ts",
      "svelte": "./dist/internal/index.js"
    },
    "./animation": {
      "types": "./dist/animation/index.d.ts",
      "svelte": "./dist/animation/index.js",
      "default": "./dist/animation/index.js"
    },
    "./animation/animationframe": {
      "types": "./dist/animation/animationframe.d.ts",
      "svelte": "./dist/animation/animationframe.js",
      "default": "./dist/animation/animationframe.js"
    },
    "./animation/util": {
      "types": "./dist/animation/util.d.ts",
      "svelte": "./dist/animation/util.js",
      "default": "./dist/animation/util.js"
    },
    "./animation/*.scss": {
      "sass": "./styles/animation/*.scss"
    },
    "./base": {
      "sass": "./styles/base/_index.scss",
      "types": "./dist/base/index.d.ts",
      "svelte": "./dist/base/index.js",
      "default": "./dist/base/index.js"
    },
    "./base/component": {
      "types": "./dist/base/component.d.ts",
      "svelte": "./dist/base/component.js",
      "default": "./dist/base/component.js"
    },
    "./base/foundation": {
      "types": "./dist/base/foundation.d.ts",
      "svelte": "./dist/base/foundation.js",
      "default": "./dist/base/foundation.js"
    },
    "./base/observer-foundation": {
      "types": "./dist/base/observer-foundation.d.ts",
      "svelte": "./dist/base/observer-foundation.js",
      "default": "./dist/base/observer-foundation.js"
    },
    "./base/observer": {
      "types": "./dist/base/observer.d.ts",
      "svelte": "./dist/base/observer.js",
      "default": "./dist/base/observer.js"
    },
    "./base/types": {
      "types": "./dist/base/types.d.ts",
      "svelte": "./dist/base/types.js",
      "default": "./dist/base/types.js"
    },
    "./tokens/*.scss": {
      "sass": "./styles/tokens/*.scss"
    },
    "./density/*.scss": {
      "sass": "./styles/density/*.scss"
    },
    "./feature-targeting/*.scss": {
      "sass": "./styles/feature-targeting/*.scss"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./src/*"
      ],
      "classadder": [
        "./src/classadder/index.d.ts"
      ],
      "events": [
        "./src/events/index.d.ts"
      ],
      "internal": [
        "./src/internal/index.d.ts"
      ],
      ".": [
        "./src/index.d.ts"
      ]
    }
  },
  "keywords": [
    "svelte",
    "svelte3",
    "material-ui",
    "material-design",
    "material",
    "svelte-components",
    "sveltejs"
  ],
  "scripts": {
    "build": "npm run build:js && npm run build:svelte",
    "build:js": "tsc -p . --outDir dist/ --rootDir src/",
    "build:svelte": "cp src/*.svelte dist/ && cp src/classadder/*.svelte dist/classadder/",
    "clean": "git status --ignored -u --porcelain . | grep -v node_modules/ | grep -e '^!! ' | sed 's/^!! packages\\/[a-z-]*\\///g' | tr '\\n' ' ' | xargs rm",
    "check": "npx svelte-check --ignore dist",
    "prepublish": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hperrin/svelte-material-ui.git"
  },
  "author": "Hunter Perrin <hperrin@gmail.com>",
  "bugs": {
    "url": "https://github.com/hperrin/svelte-material-ui/issues"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@smui/dom": "^8.0.3",
    "@smui/elevation": "^8.0.3"
  },
  "devDependencies": {
    "@tsconfig/svelte": "^5.0.8",
    "sass": "^1.97.3",
    "svelte-check": "^4.4.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
